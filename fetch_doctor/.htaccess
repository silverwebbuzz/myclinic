# =====================================================================
# fetch_doctor/.htaccess
# Allows index.php and insert_db.php; blocks everything else
# (raw JSON, .env, migration.sql).
# =====================================================================

# Block direct access to dotfiles, SQL, and JSON dumps.
<FilesMatch "(^\.|\.sql$|\.json$|\.example$|\.htaccess$)">
    Require all denied
</FilesMatch>

# Block the json/ and jobs/ subfolders entirely from the web.
RedirectMatch 403 ^/fetch_doctor/json/.*$
RedirectMatch 403 ^/fetch_doctor/jobs/.*$

Options -Indexes
