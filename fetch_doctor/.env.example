# Copy to .env on the server. Never commit .env.

# Required: Google Maps Places API key.
# Get one at: https://console.cloud.google.com → APIs & Services → Credentials.
# Enable "Places API" under Library. In Cloud Console → Billing → Budgets,
# set a daily cap so you can't be surprise-billed.
GOOGLE_MAPS_API_KEY=

# Optional DB override. Leave blank to read from ../app/.env (preferred).
# DB_HOST=127.0.0.1
# DB_DATABASE=
# DB_USERNAME=
# DB_PASSWORD=
