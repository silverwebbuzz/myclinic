{
    "name": "manageclinic/app",
    "description": "ManageClinic — multi-tenant clinic SaaS",
    "type": "project",
    "require": {
        "php": "^8.2",
        "vlucas/phpdotenv": "^5.6",
        "predis/predis": "^2.2",
        "firebase/php-jwt": "^6.10",
        "league/oauth2-google": "^4.0",
        "endroid/qr-code": "^5.0",
        "mpdf/mpdf": "^8.2",
        "phpoffice/phpspreadsheet": "^2.0",
        "picqer/php-barcode-generator": "^2.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "migrate": "php database/migrate.php",
        "seed": "php database/seed.php",
        "test": "phpunit"
    }
}
